Bootstrap: docker
From: python:3.11-slim

%post
    # Container volutamente minimale: dipendenze runtime + tonic, niente artifact.
    apt-get update && apt-get install -y git build-essential screen && rm -rf /var/lib/apt/lists/*
    python -m pip install --no-cache-dir --upgrade pip
    python -m pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu
    python -m pip install --no-cache-dir numpy pyyaml pandas matplotlib pytest tonic

%environment
    export PYTHONPATH=/workspace/pre_attention_benchmark_framework/src:$PYTHONPATH
    export MPLBACKEND=Agg

%runscript
    exec python "$@"
